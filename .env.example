# ─────────────────────────────────────────────
#  Server Configuration
# ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Allowed CORS origin (your Vite dev URL or production domain)
CLIENT_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────
#  SMTP / Nodemailer (Gmail + App Password)
#  For Gmail: enable 2FA, then create an App Password at
#  https://myaccount.google.com/apppasswords
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your_16_char_app_password

# The inbox that receives contact form submissions
MAIL_TO=you@gmail.com

# ─────────────────────────────────────────────
#  Google reCAPTCHA v3
#  Get keys at: https://www.google.com/recaptcha/admin/create
# ─────────────────────────────────────────────
RECAPTCHA_SECRET_KEY=your_recaptcha_v3_secret_key
# Score 0.0 (bot) → 1.0 (human). Reject below this threshold.
RECAPTCHA_MIN_SCORE=0.5

# ─────────────────────────────────────────────
#  Rate Limiting
# ─────────────────────────────────────────────
# Max contact form submissions per IP per window
RATE_LIMIT_MAX=3
# Window in milliseconds (900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
